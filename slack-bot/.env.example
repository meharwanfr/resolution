# Slack Bot Token (xoxb-...) - needs chat:write, users:read, users:read.email scopes
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Airtable
AIRTABLE_API_TOKEN=your_airtable_api_token
AIRTABLE_BASE_ID=your_base_id
AIRTABLE_TABLE_ID=your_ysws_project_submission_table_id

# Poll interval in milliseconds (default: 30000 = 30 seconds)
POLL_INTERVAL=30000
