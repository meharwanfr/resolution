		"@types/bcrypt": "^6.0.0",
		"@types/dompurify": "^3.2.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/pg": "^8.20.0",
		"@types/simple-oauth2": "^5.0.8",
		"@vitest/coverage-v8": "^4.1.2",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^28.1.0",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"typescript": "^5.9.3",
