		"@types/uuid": "^11.0.0",
		"airtable": "^0.12.2",
		"bcrypt": "^6.0.0",
		"canvas-confetti": "^1.9.4",
		"dompurify": "^3.3.3",
		"dotenv": "^17.4.0",
		"drizzle-orm": "^0.45.2",
		"jsonwebtoken": "^9.0.3",
		"lucia": "^3.2.2",
		"monaco-editor": "^0.55.1",
		"oslo": "^1.2.1",
		"pg": "^8.20.0",
		"simple-oauth2": "^5.1.0",
